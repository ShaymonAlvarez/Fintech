# Copie este arquivo para .env e preencha os valores

# Banco de dados (SQLite por padrão)
DATABASE_URL=sqlite:///./financas.db

# Chave secreta para JWT (MUDE ISSO!)
SECRET_KEY=minha-chave-secreta-super-segura-mude-isso

# Token do bot do Telegram (pegue com @BotFather)
TELEGRAM_BOT_TOKEN=seu-token-aqui

# Seu Telegram ID (envie /start para @userinfobot para descobrir)
ALLOWED_TELEGRAM_IDS=123456789
